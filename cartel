.btn--sm { padding: 0.375rem 0.75rem; font-size: 0.875rem; }
.btn--lg { padding: 0.875rem 1.75rem; font-size: 1.125rem; }
.btn--primary { background: oklch(0.6 0.18 265); color: white; }
