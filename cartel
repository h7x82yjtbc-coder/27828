/* Кнопка с приятным hover */
.btn-fancy {
  position: relative;
  overflow: hidden;
  transition: all var(--duration-200) var(--ease-out);
}

.btn-fancy::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    120deg,
    transparent 30%,
    rgba(255, 255, 255, 0.15) 50%,
    transparent 70%
  );
  transform: translateX(-100%);
  transition: transform var(--duration-500) var(--ease-out);
}

.btn-fancy:hover::after {
  transform: translateX(100%);
}

/* Карточка с parallax-наклоном (JS-зависимый) */
/* Лёгкий CSS-вариант: */
.card-tilt:hover {
  transform: perspective(1000px) rotateX(2deg) rotateY(-2deg) translateY(-4px);
  box-shadow: var(--shadow-xl);
}

/* Checkbox с анимацией */
.checkbox-custom {
  appearance: none;
  width: 1.25rem;
  height: 1.25rem;
  border: 2px solid var(--gray-300);
  border-radius: var(--radius-sm);
  transition: all var(--duration-150) var(--ease-in-out);
  cursor: pointer;
  position: relative;
}

.checkbox-custom:checked {
  background: var(--primary-500);
  border-color: var(--primary-500);
}

.checkbox-custom:checked::after {
  content: '✓';
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 0.75rem;
  font-weight: bold;
  animation: scaleIn var(--duration-150) var(--ease-spring);
}

/* Ripple-эффект (Material Design) */
.ripple {
  position: relative;
  overflow: hidden;
}

.ripple::after {
  content: '';
  position: absolute;
  width: 100%;
  padding-top: 100%;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0);
  opacity: 0;
}

.ripple:active::after {
  transform: translate(-50%, -50%) scale(2);
  opacity: 1;
  transition: 0s;
}

/* Skeleton Loading */
.skeleton {
  background: linear-gradient(
    90deg,
    var(--gray-200) 25%,
    var(--gray-100) 37%,
    var(--gray-200) 63%
  );
  background-size: 400% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-md);
}

.skeleton-text {
  height: 1em;
  margin-bottom: 0.5em;
}

.skeleton-text:last-child {
  width: 80%;
}

.skeleton-circle {
  width: 3rem;
  height: 3rem;
  border-radius: var(--radius-full);
}
