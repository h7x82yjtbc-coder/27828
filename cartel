.faq summary { cursor: pointer; font-weight: 600; }
.faq p { margin: 0.75rem 0 0; color: oklch(0.45 0.02 250); }

/* CTA */
.cta { background: linear-gradient(135deg, oklch(0.55 0.18 265), oklch(0.55 0.20 320)); color: white; padding: 6rem 1.5rem; text-align: center; }
.cta h2 { font-size: clamp(1.75rem, 3vw, 2.5rem); margin: 0 0 1rem; }
.cta p { font-size: 1.125rem; opacity: 0.9; margin: 0 0 2rem; }
.cta .btn--primary { background: white; color: oklch(0.55 0.18 265); }
.cta .btn--primary:hover { background: oklch(0.97 0.01 250); }

/* Footer */
.site-footer { background: oklch(0.12 0.02 250); color: oklch(0.85 0.02 250); padding: 4rem 1.5rem 2rem; }
.site-footer__cols { display: grid; gap: 2rem; grid-template-columns: 1.5fr repeat(3, 1fr); max-width: 72rem; margin: 0 auto; }
