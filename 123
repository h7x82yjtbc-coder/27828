```css
/* Шкала трекинга */
:root {
  --tracking-tightest: -0.05em;  /* Очень плотно — для огромных заголовков */
  --tracking-tighter:  -0.04em;
  --tracking-tight:    -0.02em;  /* Стандартно для заголовков */
  --tracking-normal:   0;        /* Тело текста */
  --tracking-wide:     0.025em;
  --tracking-wider:    0.05em;   /* Для CAPS-текста */
  --tracking-widest:   0.1em;    /* Для очень разрежённых */
}

/* Правила:
   - Большой текст → отрицательный трекинг (плотно)
   - Маленький текст (caps, labels) → положительный
   - Тело → 0 или совсем чуть-чуть
*/

.label-uppercase {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: var(--tracking-widest);
  font-weight: 600;
}

.huge-display {
