#### Custom Hooks
```tsx
function useFetch<T>(url: string) {
  const [data, setData] = useState<T | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    let cancelled = false;

    fetch(url)
      .then(r => r.json())
      .then(d => !cancelled && (setData(d), setLoading(false)))
      .catch(e => !cancelled && (setError(e), setLoading(false)));

    return () => { cancelled = true; };
  }, [url]);

  return { data, loading, error };
}
```

#### Context + Reducer (мини-Redux)
```tsx
type State = { count: number };
type Action = { type: 'increment' } | { type: 'decrement' };

const reducer = (s: State, a: Action): State => {
  switch (a.type) {
    case 'increment': return { count: s.count + 1 };
    case 'decrement': return { count: s.count - 1 };
  }
};

const StoreContext = createContext<{
  state: State;
  dispatch: Dispatch<Action>;
} | null>(null);

export const StoreProvider = ({ children }) => {
  const [state, dispatch] = useReducer(reducer, { count: 0 });
  return (
    <StoreContext.Provider value={{ state, dispatch }}>
      {children}
    </StoreContext.Provider>
  );
};

export const useStore = () => {
  const ctx = useContext(StoreContext);
  if (!ctx) throw new Error('useStore must be inside StoreProvider');
  return ctx;
};
```

### 29.5 API Design — RESTful

```
ПРИНЦИПЫ REST:

1. RESOURCES (Ресурсы)
   URL = существительные, не глаголы

   ❌ /getUsers, /createUser, /deleteUser/123
   ✅ /users          GET
   ✅ /users          POST
   ✅ /users/123      GET / PUT / DELETE

2. HTTP МЕТОДЫ
   GET    — получить данные
   POST   — создать
   PUT    — обновить (целиком)
   PATCH  — обновить (частично)
   DELETE — удалить

3. КОДЫ ОТВЕТОВ
   200 OK                — успех
   201 Created           — успешно создано
   204 No Content        — успех, тело пустое
   301 Moved Permanently — переехало
   400 Bad Request       — клиент ошибся
   401 Unauthorized      — нужна авторизация
   403 Forbidden         — нет прав
   404 Not Found         — не найдено
   409 Conflict          — конфликт (дубликат)
   422 Unprocessable     — валидация не прошла
   429 Too Many Requests — rate limit
   500 Internal Error    — сервер сломался
   502 Bad Gateway       — proxy не получил ответ
   503 Service Unavailable — сервер перегружен

4. ИЕРАРХИЯ
   /users/123/posts/456/comments

5. ФИЛЬТРАЦИЯ И ПАГИНАЦИЯ
   GET /users?status=active&role=admin
   GET /users?page=2&per_page=20
   GET /users?sort=-created_at  (минус = убывание)

6. ВЕРСИОНИРОВАНИЕ
   /api/v1/users
   /api/v2/users
   Или через header: Accept: application/vnd.api+json;version=2

7. ИДЕМПОТЕНТНОСТЬ
   GET, PUT, DELETE — идемпотентны (повторение = тот же результат)
   POST — не идемпотентен
```

